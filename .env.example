# Local Postgres connection (create with: createdb orange_blossom)
DATABASE_URL="postgresql://obs:obs_local_dev@localhost:5432/orange_blossom?schema=public"
# Secret used to sign JWTs — generate a long random string for production
JWT_SECRET="change_me_to_a_long_random_string"
JWT_EXPIRES_IN="7d"
# Backend API port (Vite dev server proxies /api here)
PORT=4000
NODE_ENV=development
