# Local Postgres connection (create with: createdb orange_blossom)
DATABASE_URL="postgresql://obs:obs_local_dev@localhost:5432/orange_blossom?schema=public"
# Secret used to sign JWTs — generate a long random string for production
JWT_SECRET="change_me_to_a_long_random_string"
JWT_EXPIRES_IN="7d"
# Backend API port (Vite dev server proxies /api here)
PORT=4000
NODE_ENV=development
# Public base URL (used in password-reset links)
APP_BASE_URL="http://localhost:5174"

# --- Integrations (OPTIONAL) ---
# You do NOT need to set these. Each deployment enters its own keys in the app at
# Settings -> Integrations (stored in the DB and used at call time; DB overrides
# env). Set them here only if you prefer env-based config over the UI.
#
# Twilio SMS — use a sendable number as TWILIO_SMS_NUMBER (not one wired to a
# webhook/another app). Keys also enterable in Settings -> Integrations.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_NUMBER=""
# Resend email — verified-domain sender recommended so you can email any recipient.
RESEND_API_KEY=""
EMAIL_FROM="Orange Blossom Lawncare <onboarding@resend.dev>"
QUOTE_INBOX="hello@orangeblossom.com"
# Optional: token that gates the public calendar .ics feed (/api/calendar/jobs.ics)
CALENDAR_FEED_TOKEN="change-me-calendar-feed-token"
